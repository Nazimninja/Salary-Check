---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found | SalaryTools.us" description="The page you're looking for doesn't exist. Try our free salary calculators.">
<div class="container" style="max-width:500px;padding:6rem 1.5rem;text-align:center;">
  <div style="font-family:var(--font-display);font-size:80px;font-weight:700;color:var(--bd2);line-height:1;margin-bottom:1rem;">404</div>
  <h1 style="font-family:var(--font-display);font-size:24px;font-weight:700;margin-bottom:10px;letter-spacing:-0.5px;">Page not found</h1>
  <p style="color:var(--ink3);font-size:15px;margin-bottom:2rem;line-height:1.6;">The page you're looking for doesn't exist. Try one of our free salary calculators.</p>
  <div style="display:flex;flex-direction:column;gap:10px;">
    <a href="/" style="background:var(--blue);color:#fff;padding:12px 24px;border-radius:12px;text-decoration:none;font-weight:600;font-family:var(--font-display);">Hourly → Salary Calculator</a>
    <a href="/salary-calculator" style="background:var(--surf);color:var(--blue);padding:12px 24px;border-radius:12px;text-decoration:none;font-weight:600;border:1.5px solid var(--bd2);font-family:var(--font-display);">Take-Home Pay Calculator</a>
  </div>
</div>
</Base>
