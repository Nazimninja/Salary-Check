  },
  'Retirement': {
    gradient: 'linear-gradient(135deg, #059669, #0d9488)',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" style="width:40px;height:40px;opacity:0.9;"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" /></svg>`
  },
  'Savings': {
    gradient: 'linear-gradient(135deg, #0284c7, #2563eb)',
    svg: `<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" style="width:40px;height:40px;opacity:0.9;"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18-3a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6m18 0V3.75A1.5 1.5 0 0019.5 2.25H4.5A1.5 1.5 0 003 3.75V6" /></svg>`
