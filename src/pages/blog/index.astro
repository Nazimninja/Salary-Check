---
<Base title="US Salary & Tax Guides | SalaryTools Blog" description="Free guides on US salaries, paychecks, taxes, 401k, and salary negotiation. Updated for 2025." page="blog">
<div style="text-align:center;padding:4rem 1.5rem 2.5rem;">
  <div class="sec-label">Blog</div>
  <h1 style="font-family:var(--font-display);font-size:clamp(28px,5vw,42px);font-weight:700;letter-spacing:-1.5px;margin:0.5rem 0 1rem;">Understand your paycheck</h1>
  <p style="font-size:16px;color:var(--ink3);max-width:420px;margin:0 auto;line-height:1.65;">Plain-English guides on US salaries, taxes, 401k, and negotiating better pay.</p>
</div>
<section style="padding:1rem 0 5rem;">
  <div class="container">
    <div class="blog-grid">
      {posts.map(p => (
        <a href={`/blog/${p.slug}`} class="blog-card">
          <div class="blog-card-img" style={{ background: (categoryMeta[p.tag] || categoryMeta['Guide']).gradient }} set:html={(categoryMeta[p.tag] || categoryMeta['Guide']).svg}>
          </div>
          <div class="blog-card-body">
            <div class="blog-tag">{p.tag}</div>
            <div class="blog-card-title">{p.title}</div>
            <div class="blog-card-excerpt">{p.excerpt}</div>
            <div class="blog-card-meta"><span>{p.date}</span><span>·</span><span>{p.readTime} read</span></div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
</Base>
