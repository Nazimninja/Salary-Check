---
import '../styles/global.css';
interface Props {
  title: string;
  description: string;
  canonical?: string;
  page?: string;
  schema?: string;
}
const { title, description, canonical, page = '', schema } = Astro.props;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = 'https://salarytools.us/og-image.png';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
  <meta name="googlebot" content="index, follow" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang="en-us" href={canonicalURL} />
  <link rel="alternate" hreflang="en" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="SalaryTools.us" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Geo targeting - US -->
  <meta name="geo.region" content="US" />
  <meta name="geo.placename" content="United States" />
  <meta name="language" content="English" />
  <meta name="target" content="all" />
  <meta name="audience" content="all" />
  <meta name="coverage" content="Worldwide" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />
  <meta name="theme-color" content="#2563eb" />

  <!-- WebSite Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "SalaryTools.us",
    "url": "https://salarytools.us",
    "description": "Free US salary calculators — hourly to annual converter and take-home pay calculator for all 50 states.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://salarytools.us/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  <!-- Organization Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "SalaryTools.us",
    "url": "https://salarytools.us",
    "logo": "https://salarytools.us/favicon.svg",
    "sameAs": []
  }
  </script>
</head>
<body>

<!-- TOP AGENCY PROMO BANNER -->
<div style="background: #0f172a; border-bottom: 1px solid rgba(255, 255, 255, 0.08); color: rgba(255, 255, 255, 0.85); text-align: center; font-size: 13px; padding: 10px 16px; font-weight: 500; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap; z-index: 1000; position: relative;">
  <span>Brought to you by <strong style="font-weight: 700; color: #fff;">Social Ninja's AI Agency</strong> — Need help automating or scaling your business?</span>
  <a href="https://socialninjas.in/contact" target="_blank" style="color: #60a5fa; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; transition: color 0.2s;" onmouseover="this.style.color='#93c5fd'" onmouseout="this.style.color='#60a5fa'">Get Free Audit →</a>
</div>

<nav>
  <a class="logo" href="/">
    <div class="logo-mark">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </div>
    <span class="logo-name">Salary<em>Tools</em></span>
  </a>
  <div class="nav-tools">
    <a href="/" class={`nav-tool-btn ${page === 'hourly' ? 'active' : ''}`}>Hourly ↔ Salary</a>
    <a href="/salary-calculator" class={`nav-tool-btn ${page === 'salary' ? 'active' : ''}`}>Take-Home Pay</a>
    <a href="/blog" class={`nav-tool-btn ${page === 'blog' ? 'active' : ''}`}>Blog</a>
  </div>
  <div class="nav-right">
    <span class="nav-pill">🇺🇸 US Tools</span>
    
    <!-- Mobile Hamburger Toggle -->
    <button class="mobile-menu-btn" id="menuBtn" aria-label="Toggle Menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6" class="line1"></line>
        <line x1="3" y1="12" x2="21" y2="12" class="line2"></line>
        <line x1="3" y1="18" x2="21" y2="18" class="line3"></line>
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile Sliding Drawer -->
<div class="mobile-drawer" id="mobileDrawer">
  <div class="drawer-links">
    <a href="/" class={`drawer-link ${page === 'hourly' ? 'active' : ''}`}>Hourly ↔ Salary Converter</a>
    <a href="/salary-calculator" class={`drawer-link ${page === 'salary' ? 'active' : ''}`}>Take-Home Pay Calculator</a>
    <a href="/blog" class={`drawer-link ${page === 'blog' ? 'active' : ''}`}>Guides & Blog</a>
  </div>
  
  <div class="drawer-promo-card">
    <div class="promo-title">Social Ninja's AI Agency</div>
    <div class="promo-text">We build automated client acquisition systems, custom chatbots, and manage high-converting Meta/Google ad campaigns.</div>
    <a href="https://socialninjas.in/contact" target="_blank" class="promo-btn">Get Free Growth Audit →</a>
  </div>
</div>

<script is:inline>
  const btn = document.getElementById('menuBtn');
  const drawer = document.getElementById('mobileDrawer');
  if (btn && drawer) {
    btn.addEventListener('click', () => {
      drawer.classList.toggle('open');
      btn.classList.toggle('active');
      document.body.style.overflow = drawer.classList.contains('open') ? 'hidden' : '';
    });
  }
</script>

<style>
/* Responsive Mobile Drawer CSS */
.mobile-menu-btn {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink);
  padding: 4px;
  z-index: 1100;
  margin-left: 10px;
}
.mobile-menu-btn svg {
  width: 22px;
  height: 22px;
}
.mobile-drawer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  padding: 100px 2rem 40px;
  transform: translateX(100%);
  transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  overflow-y: auto;
}
.mobile-drawer.open {
  transform: translateX(0);
}
.drawer-links {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin-bottom: 2rem;
}
.drawer-link {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 700;
  text-decoration: none;
  color: var(--ink2);
  letter-spacing: -0.4px;
}
.drawer-link.active {
  color: var(--blue);
}
.drawer-promo-card {
  margin-top: auto;
  background: linear-gradient(135deg, #0f172a, #1e293b);
  border-radius: 18px;
  padding: 22px;
  color: #fff;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 10px 30px rgba(15,23,42,0.25);
}
.promo-title {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 6px;
  color: #60a5fa;
}
.promo-text {
  font-size: 12.5px;
  color: rgba(255,255,255,0.65);
  line-height: 1.6;
  margin-bottom: 16px;
}
.promo-btn {
  display: block;
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  color: #fff !important;
  text-decoration: none;
  font-weight: 600;
  font-size: 13.5px;
  padding: 11px 18px;
  border-radius: 10px;
  text-align: center;
  box-shadow: 0 4px 16px rgba(37,99,235,0.3);
}

.mobile-menu-btn svg line {
  transform-origin: center;
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.mobile-menu-btn.active .line1 {
  transform: translateY(6px) rotate(45deg);
}
.mobile-menu-btn.active .line2 {
  opacity: 0;
}
.mobile-menu-btn.active .line3 {
  transform: translateY(-6px) rotate(-45deg);
}

@media(max-width: 768px) {
  .nav-tools { display: none !important; }
  .mobile-menu-btn { display: block !important; }
}
</style>

<slot />

<!-- DISCLAIMER BANNER -->
<div class="disclaimer-bar">
  <div class="container">
    ⚠️ <strong>Disclaimer:</strong> Calculations are estimates for informational purposes only. Tax situations vary. Consult a qualified CPA or tax professional for advice specific to your situation.
  </div>
</div>

<footer>
  <div class="ft-inner">
    <div>
      <div class="ft-logo">Salary<em>Tools</em></div>
      <div class="ft-tagline">Free salary calculators for US workers · 2025</div>
    </div>
    <div class="ft-col">
      <h4>Tools</h4>
      <a href="/">Hourly ↔ Salary Converter</a>
      <a href="/salary-calculator">Take-Home Pay Calculator</a>
    </div>
    <div class="ft-col">
      <h4>Guides</h4>
      <a href="/blog/hourly-to-salary-guide">Hourly to Salary Guide</a>
      <a href="/blog/us-take-home-pay-guide">Take-Home Pay Guide</a>
      <a href="/blog/salary-negotiation-guide">Salary Negotiation</a>
      <a href="/blog/401k-guide-beginners">401k Guide</a>
    </div>
    <div class="ft-col">
      <h4>Company</h4>
      <a href="/about">About</a>
      <a href="/privacy">Privacy Policy</a>
    </div>
  </div>
  <div class="ft-copy">
    © 2025 SalaryTools.us · Free US salary calculators · Powered by <a href="https://socialninjas.in" target="_blank" style="color: #60a5fa; text-decoration: none; font-weight: 600;">Social Ninja's AI Agency</a> · <a href="/privacy" style="color:#475569;">Privacy</a>
  </div>
</footer>

<div class="toast" id="toast"></div>
</body>
</html>
